{
  "expo": {
    "name": "사진 가이드",
    "slug": "photo-guide",
    "scheme": "photoguide",
    "description": "사진 구도를 맞추고 쇼츠·릴스용 콘텐츠 제작을 돕는 촬영 가이드 앱입니다.",
    "version": "1.0.0",
    "runtimeVersion": {
      "policy": "appVersion"
    },
    "orientation": "portrait",
    "icon": "./assets/icons/app-icon.png",
    "userInterfaceStyle": "automatic",
    "ios": {
      "supportsTablet": false,
      "bundleIdentifier": "com.haebi.photoguide",
      "buildNumber": "1",
      "infoPlist": {
        "NSCameraUsageDescription": "사진 가이드에서 구도 가이드 촬영을 위해 카메라 접근 권한이 필요합니다.",
        "NSPhotoLibraryUsageDescription": "사진 가이드에서 기준 사진을 불러오고 편집하기 위해 사진 보관함 접근 권한이 필요합니다.",
        "NSPhotoLibraryAddUsageDescription": "사진 가이드에서 촬영 사진과 편집 결과를 저장하기 위해 사진 저장 권한이 필요합니다."
      }
    },
    "android": {
      "package": "com.haebi.photoguide",
      "versionCode": 1,
      "blockedPermissions": [
        "android.permission.RECORD_AUDIO"
      ],
      "adaptiveIcon": {
        "foregroundImage": "./assets/icons/adaptive-icon.png",
        "backgroundColor": "#ffffff"
      }
    },
    "web": {
      "bundler": "metro",
      "output": "static",
      "favicon": "./assets/icons/favicon.png"
    },
    "plugins": [
      "expo-router",
      [
        "expo-camera",
        {
          "cameraPermission": "사진 가이드에서 구도 가이드 촬영을 위해 카메라 접근 권한이 필요합니다.",
          "microphonePermission": false,
          "recordAudioAndroid": false,
          "barcodeScannerEnabled": false
        }
      ],
      [
        "expo-image-picker",
        {
          "photosPermission": "사진 가이드에서 기준 사진을 불러오고 편집하기 위해 사진 보관함 접근 권한이 필요합니다.",
          "cameraPermission": "사진 가이드에서 사진 촬영 기능을 사용하기 위해 카메라 접근 권한이 필요합니다.",
          "microphonePermission": false
        }
      ],
      [
        "expo-media-library",
        {
          "photosPermission": "사진 가이드에서 기준 사진을 불러오고 편집하기 위해 사진 보관함 접근 권한이 필요합니다.",
          "savePhotosPermission": "사진 가이드에서 촬영 사진과 편집 결과를 저장하기 위해 사진 저장 권한이 필요합니다.",
          "isAccessMediaLocationEnabled": false,
          "granularPermissions": [
            "photo",
            "video"
          ]
        }
      ],
      "expo-document-picker",
      [
        "expo-audio",
        {
          "microphonePermission": false,
          "recordAudioAndroid": false,
          "enableBackgroundPlayback": false,
          "enableBackgroundRecording": false
        }
      ]
    ],
    "experiments": {
      "typedRoutes": true
    }
  }
}
