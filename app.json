{
  "expo": {
    "name": "트래블프레임",
    "slug": "photo-guide",
    "scheme": [
      "photoguide",
      "com.haebi.photoguide"
    ],
    "description": "여행 사진의 구도를 맞추고 쇼츠·릴스용 콘텐츠 제작을 돕는 촬영 가이드 앱입니다.",
    "version": "1.0.4",
    "runtimeVersion": {
      "policy": "appVersion"
    },
    "orientation": "portrait",
    "icon": "./assets/icons/app-icon.png",
    "splash": {
      "image": "./assets/icons/splash-icon.png",
      "resizeMode": "contain",
      "backgroundColor": "#111111"
    },
    "newArchEnabled": true,
    "userInterfaceStyle": "automatic",
    "ios": {
      "supportsTablet": false,
      "bundleIdentifier": "com.haebi.photoguide",
      "buildNumber": "1",
      "infoPlist": {
        "NSCameraUsageDescription": "트래블프레임에서 구도 가이드 촬영을 위해 카메라 접근 권한이 필요합니다.",
        "NSPhotoLibraryUsageDescription": "트래블프레임에서 기준 사진을 불러오고 편집하기 위해 사진 보관함 접근 권한이 필요합니다.",
        "NSPhotoLibraryAddUsageDescription": "트래블프레임에서 촬영 사진과 편집 결과를 저장하기 위해 사진 저장 권한이 필요합니다."
      }
    },
    "android": {
      "package": "com.haebi.photoguide",
      "versionCode": 6,
      "blockedPermissions": [
        "android.permission.RECORD_AUDIO"
      ],
      "adaptiveIcon": {
        "foregroundImage": "./assets/icons/adaptive-icon.png",
        "backgroundColor": "#111111"
      },
      "splash": {
        "image": "./assets/icons/splash-icon.png",
        "resizeMode": "contain",
        "backgroundColor": "#111111"
      },
      "permissions": [
        "android.permission.CAMERA",
        "android.permission.READ_EXTERNAL_STORAGE",
        "android.permission.WRITE_EXTERNAL_STORAGE",
        "android.permission.READ_MEDIA_VISUAL_USER_SELECTED",
        "android.permission.READ_MEDIA_IMAGES",
        "android.permission.READ_MEDIA_VIDEO",
        "android.permission.MODIFY_AUDIO_SETTINGS",
        "com.google.android.gms.permission.AD_ID"
      ]
    },
    "web": {
      "bundler": "metro",
      "output": "static",
      "favicon": "./assets/icons/favicon.png"
    },
    "plugins": [
      "expo-router",
      [
        "expo-camera",
        {
          "cameraPermission": "트래블프레임에서 구도 가이드 촬영을 위해 카메라 접근 권한이 필요합니다.",
          "microphonePermission": false,
          "recordAudioAndroid": false,
          "barcodeScannerEnabled": false
        }
      ],
      [
        "expo-image-picker",
        {
          "photosPermission": "트래블프레임에서 기준 사진을 불러오고 편집하기 위해 사진 보관함 접근 권한이 필요합니다.",
          "cameraPermission": "트래블프레임에서 사진 촬영 기능을 사용하기 위해 카메라 접근 권한이 필요합니다.",
          "microphonePermission": false
        }
      ],
      [
        "expo-media-library",
        {
          "photosPermission": "트래블프레임에서 기준 사진을 불러오고 편집하기 위해 사진 보관함 접근 권한이 필요합니다.",
          "savePhotosPermission": "트래블프레임에서 촬영 사진과 편집 결과를 저장하기 위해 사진 저장 권한이 필요합니다.",
          "isAccessMediaLocationEnabled": false,
          "granularPermissions": [
            "photo",
            "video"
          ]
        }
      ],
      "expo-document-picker",
      [
        "expo-audio",
        {
          "microphonePermission": false,
          "recordAudioAndroid": false,
          "enableBackgroundPlayback": false,
          "enableBackgroundRecording": false
        }
      ],
      "expo-web-browser",
      [
        "react-native-google-mobile-ads",
        {
          "androidAppId": "ca-app-pub-3239289311207399~9959086380",
          "optimizeInitialization": true,
          "optimizeAdLoading": true
        }
      ]
    ],
    "experiments": {
      "typedRoutes": true
    },
    "react-native-google-mobile-ads": {
      "android_app_id": "ca-app-pub-3239289311207399~9959086380"
    },
    "extra": {
      "router": {},
      "privacyPolicyUrl": "https://sevim0104.cafe24.com/privacy/index.html",
      "admob": {
        "androidAppId": "ca-app-pub-3239289311207399~9959086380",
        "androidBannerAdUnitId": "ca-app-pub-3239289311207399/3281997392",
        "androidInterstitialAdUnitId": ""
      },
      "eas": {
        "projectId": "36ca0ec3-771c-4cd9-9700-4610ea87edb9"
      }
    }
  }
}
