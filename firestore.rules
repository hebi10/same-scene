rules_version = '2';

service cloud.firestore {
  match /databases/{database}/documents {
    function signedIn() {
      return request.auth != null;
    }

    function isOwner(userId) {
      return signedIn() && request.auth.uid == userId;
    }

    function isAdmin() {
      return signedIn()
        && exists(/databases/$(database)/documents/admins/$(request.auth.uid));
    }

    function isCurrentUserDocument(userId) {
      return request.resource.data.uid == userId;
    }

    function isMockProductId() {
      return request.resource.data.productId == "ad_remove"
        || request.resource.data.productId == "creator_monthly";
    }

    function isValidMockSubscriptionDocument(subscriptionId) {
      return subscriptionId == "current"
        || subscriptionId == request.resource.data.productId;
    }

    function isMockSubscription(subscriptionId) {
      return request.resource.data.plan == "premium"
        && request.resource.data.status == "active"
        && request.resource.data.provider == "mock"
        && isMockProductId()
        && isValidMockSubscriptionDocument(subscriptionId)
        && (
          (
            request.resource.data.productId == "ad_remove"
            && request.resource.data.expiresAt == null
            && request.resource.data.priceLabel == "3,900원"
            && request.resource.data.productName == "광고 제거"
          )
          || (
            request.resource.data.productId == "creator_monthly"
            && request.resource.data.expiresAt is string
            && request.resource.data.priceLabel == "월 3,900원"
            && request.resource.data.productName == "영상 내보내기"
          )
        );
    }

    function isMockPaymentEvent() {
      return request.resource.data.type == "mock_payment_completed"
        && request.resource.data.provider == "mock"
        && request.resource.data.plan == "premium"
        && isMockProductId()
        && (
          (
            request.resource.data.productId == "ad_remove"
            && request.resource.data.productName == "광고 제거"
            && request.resource.data.priceLabel == "3,900원"
          )
          || (
            request.resource.data.productId == "creator_monthly"
            && request.resource.data.productName == "영상 내보내기"
            && request.resource.data.priceLabel == "월 3,900원"
          )
        );
    }

    function isAdminSubscriptionDocument(subscriptionId) {
      return subscriptionId == "current"
        || subscriptionId == "ad_remove"
        || subscriptionId == "creator_monthly";
    }

    match /users/{userId} {
      allow read: if isOwner(userId) || isAdmin();
      allow create: if isOwner(userId) && isCurrentUserDocument(userId);
      allow update: if isOwner(userId)
        && resource.data.uid == userId
        && isCurrentUserDocument(userId);
      allow delete: if false;

      match /videos/{videoId} {
        allow read, create, update, delete: if isOwner(userId) || isAdmin();
      }

      match /imageWorks/{workId} {
        allow read, create, update, delete: if isOwner(userId) || isAdmin();
      }

      match /musicTracks/{trackId} {
        allow read, create, update, delete: if isOwner(userId) || isAdmin();
      }

      match /backups/{backupId} {
        allow read, create, update, delete: if isOwner(userId) || isAdmin();
      }

      match /photoBackups/{photoId} {
        allow read, create, update, delete: if isOwner(userId) || isAdmin();
      }

      match /usage/{usageGroup}/weeks/{weekId} {
        allow read: if isOwner(userId) || isAdmin();
        allow create, update: if isOwner(userId)
          && usageGroup == "videoExports"
          && request.resource.data.userId == userId
          && request.resource.data.weekId == weekId
          && request.resource.data.count is int
          && request.resource.data.count >= 0
          && request.resource.data.count <= 1
          && request.resource.data.limit == 1;
        allow delete: if isAdmin();
      }

      match /subscriptions/{subscriptionId} {
        allow read: if isOwner(userId) || isAdmin();

        // Temporary client-side mock payment flow.
        // Replace create/update with trusted server-only writes when real billing is added.
        allow create, update: if isOwner(userId)
          && isAdminSubscriptionDocument(subscriptionId)
          && isMockSubscription(subscriptionId);
        allow create, update: if isAdmin() && isAdminSubscriptionDocument(subscriptionId);

        allow delete: if isAdmin();
      }

      match /paymentEvents/{eventId} {
        allow read: if isOwner(userId) || isAdmin();

        // Temporary client-side mock payment flow.
        // Real payment events should be written by Cloud Functions or a verified server.
        allow create: if isOwner(userId) && isMockPaymentEvent();
        allow create: if isAdmin();
        allow update, delete: if false;
      }
    }

    match /admins/{adminId} {
      allow read: if isOwner(adminId);
      allow write: if false;
    }

    match /{document=**} {
      allow read, write: if false;
    }
  }
}
