rules_version = '2';

service firebase.storage {
  match /b/{bucket}/o {
    function signedIn() {
      return request.auth != null;
    }

    function isOwner(userId) {
      return signedIn() && request.auth.uid == userId;
    }

    function isImageUpload() {
      return request.resource.size < 20 * 1024 * 1024
        && request.resource.contentType.matches('image/(jpeg|jpg|png|webp)');
    }

    function isVideoUpload() {
      return request.resource.size < 250 * 1024 * 1024
        && request.resource.contentType == 'video/mp4';
    }

    match /users/{userId}/{allPaths=**} {
      allow read: if isOwner(userId);
      allow create, update: if isOwner(userId)
        && (isImageUpload() || isVideoUpload());
      allow delete: if isOwner(userId);
    }

    match /{allPaths=**} {
      allow read, write: if false;
    }
  }
}
