{
  "name": "travel-frame",
  "version": "1.0.0",
  "private": true,
  "main": "expo-router/entry",
  "scripts": {
    "start": "expo start",
    "android": "expo run:android",
    "android:dev": "expo start --dev-client --android",
    "android:uninstall": "powershell -NoProfile -ExecutionPolicy Bypass -Command \"adb uninstall com.haebi.photoguide; exit 0\"",
    "android:run-latest": "eas build:run --platform android --latest",
    "android:reset-install": "npm run android:uninstall && npm run android:run-latest",
    "android:build-dev": "eas build --profile development --platform android",
    "android:build-prod": "eas build --platform android --profile production",
    "android:build-prod-local": "powershell -NoProfile -ExecutionPolicy Bypass -File scripts/build-android-aab.ps1",
    "ios": "expo run:ios",
    "web": "expo start --web",
    "lint": "expo lint",
    "typecheck": "tsc --noEmit",
    "firebase:deploy-rules": "firebase deploy --only firestore:rules,storage --project travelframe-4e1fb",
    "firebase:deploy-functions": "firebase deploy --only functions --project travelframe-4e1fb",
    "firebase:deploy-hosting": "firebase deploy --only hosting --project travelframe-4e1fb",
    "firebase:deploy-all": "firebase deploy --only hosting,firestore:rules,storage,functions --project travelframe-4e1fb",
    "deploy:firebase": "firebase deploy --only hosting,firestore:rules,storage,functions --project travelframe-4e1fb",
    "render-server": "node server/render-server.mjs",
    "install:media": "npx expo install expo-camera expo-media-library expo-image-manipulator expo-image-picker expo-audio expo-video expo-document-picker expo-file-system expo-sharing expo-haptics expo-image react-native-reanimated react-native-worklets react-native-gesture-handler @react-native-async-storage/async-storage",
    "install:ads": "npx expo install react-native-google-mobile-ads"
  },
  "dependencies": {
    "@react-native-async-storage/async-storage": "2.2.0",
    "expo": "^55.0.0",
    "expo-audio": "^55.0.0",
    "expo-auth-session": "~55.0.16",
    "expo-camera": "^55.0.0",
    "expo-constants": "^55.0.0",
    "expo-dev-client": "~55.0.33",
    "expo-document-picker": "^55.0.0",
    "expo-file-system": "^55.0.0",
    "expo-haptics": "^55.0.0",
    "expo-image": "^55.0.0",
    "expo-image-manipulator": "^55.0.0",
    "expo-image-picker": "~55.0.20",
    "expo-linking": "^55.0.0",
    "expo-media-library": "^55.0.0",
    "expo-router": "^55.0.0",
    "expo-sharing": "^55.0.0",
    "expo-status-bar": "^55.0.0",
    "expo-system-ui": "^55.0.0",
    "expo-video": "^55.0.0",
    "expo-web-browser": "~55.0.16",
    "firebase": "^12.13.0",
    "react": "19.2.0",
    "react-dom": "19.2.0",
    "react-native": "0.83.6",
    "react-native-gesture-handler": "~2.30.0",
    "react-native-google-mobile-ads": "^16.3.3",
    "react-native-reanimated": "4.2.1",
    "react-native-safe-area-context": "~5.6.2",
    "react-native-screens": "~4.23.0",
    "react-native-view-recorder": "^0.4.1",
    "react-native-web": "~0.21.0",
    "react-native-worklets": "0.7.4"
  },
  "devDependencies": {
    "@types/react": "^19.2.0",
    "eslint": "^9.0.0",
    "eslint-config-expo": "^55.0.0",
    "typescript": "^5.9.0"
  }
}
