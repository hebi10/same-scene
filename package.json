{
  "name": "travel-frame",
  "version": "1.0.0",
  "private": true,
  "main": "expo-router/entry",
  "scripts": {
    "start": "expo start",
    "android": "expo start --android",
    "ios": "expo start --ios",
    "web": "expo start --web",
    "lint": "expo lint",
    "typecheck": "tsc --noEmit",
    "render-server": "node server/render-server.mjs",
    "install:media": "npx expo install expo-camera expo-media-library expo-image-manipulator expo-image-picker expo-audio expo-video expo-document-picker expo-file-system expo-sharing expo-haptics expo-image react-native-reanimated react-native-worklets react-native-gesture-handler @react-native-async-storage/async-storage"
  },
  "dependencies": {
    "@react-native-async-storage/async-storage": "2.2.0",
    "expo": "^55.0.0",
    "expo-audio": "^55.0.0",
    "expo-camera": "^55.0.0",
    "expo-constants": "^55.0.0",
    "expo-document-picker": "^55.0.0",
    "expo-file-system": "^55.0.0",
    "expo-haptics": "^55.0.0",
    "expo-image": "^55.0.0",
    "expo-image-manipulator": "^55.0.0",
    "expo-image-picker": "~55.0.20",
    "expo-linking": "^55.0.0",
    "expo-media-library": "^55.0.0",
    "expo-router": "^55.0.0",
    "expo-sharing": "^55.0.0",
    "expo-status-bar": "^55.0.0",
    "expo-system-ui": "^55.0.0",
    "expo-video": "^55.0.0",
    "react": "19.2.0",
    "react-dom": "19.2.0",
    "react-native": "0.83.6",
    "react-native-gesture-handler": "~2.30.0",
    "react-native-reanimated": "4.2.1",
    "react-native-safe-area-context": "~5.6.2",
    "react-native-screens": "~4.23.0",
    "react-native-web": "~0.21.0",
    "react-native-worklets": "0.7.4"
  },
  "devDependencies": {
    "@types/react": "^19.2.0",
    "eslint": "^9.0.0",
    "eslint-config-expo": "^55.0.0",
    "typescript": "^5.9.0"
  }
